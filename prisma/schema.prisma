generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  githubUsername  String?
  linkedinUrl     String?
  targetRole      String?
  experienceLevel String?   // 'ENTRY', 'MID', 'SENIOR', 'LEAD'
  resumes       Resume[]
  githubData    GitHubData?
  suggestions   Suggestion[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Resume {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String          @default("My Resume")
  versions    ResumeVersion[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ResumeVersion {
  id           String    @id @default(cuid())
  resumeId     String
  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versionName  String    @default("v1")
  
  // Content (JSON or structured)
  personalInfo Json      @default("{}")
  summary      String    @default("")
  skills       Json      @default("{\"languages\":[],\"frameworks\":[],\"tools\":[]}")
  experience   Json      @default("[]")
  projects     Json      @default("[]")
  education    Json      @default("[]")
  achievements Json      @default("[]")
  
  // Metadata
  atsScore     Int       @default(0)
  isMain       Boolean   @default(false)
  jobTargetId  String?
  jobTarget    JobTarget? @relation(fields: [jobTargetId], references: [id])
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model JobTarget {
  id             String    @id @default(cuid())
  title          String
  company        String?
  description    String    // The pasted JD
  keywords       Json      @default("[]")
  missingSkills  Json      @default("[]")
  matchScore     Int       @default(0)
  versions       ResumeVersion[]
  createdAt      DateTime  @default(now())
}

model GitHubData {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Json     @default("[]")
  signals      Json     @default("{}") // AI-inferred engineering signals
  accessToken  String?  // Saved during OAuth login for background sync
  lastSyncedAt DateTime @default(now())
}

model Suggestion {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // 'NEW_PROJECT' | 'IMPROVE_PROJECT' | 'ADD_SKILL'
  entityId     String?  
  title        String
  description  String
  proposedData String   
  currentData  String?  
  priority     Int      @default(1)
  confidence   Float    @default(0.0)
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  rating    Int
  message   String
  createdAt DateTime @default(now())
}
